# DVAP — .env.example
#
# Copy to .env and adjust if needed. Most values have sane compose defaults.
# None of these should ever be real credentials; DVAP uses watermarked synthetic
# seeds only (see seeds/synthetic.env).

# ---------------------------------------------------------------------------
# Published port bindings (all bind to 127.0.0.1 by default — SPEC §2)
# ---------------------------------------------------------------------------
FRONTEND_PORT=8080        # http://127.0.0.1:8080  — operator UI
API_PORT=8000             # http://127.0.0.1:8000  — REST + WebSocket
LISTENER_PORT=9000        # http://127.0.0.1:9000  — OOB beacon receiver (debug)
POSTGRES_PORT=54329       # 127.0.0.1:54329       — local Postgres access

# ---------------------------------------------------------------------------
# Inter-service URLs (used by services on the dvap-net bridge network)
# ---------------------------------------------------------------------------
DVAP_WORKER_URL=http://worker:8100   # api → worker (not published externally)
DVAP_API_URL=http://api:8000         # listener → api (internal)
DVAP_DATABASE_URL=postgresql://dvap_app:FAKE_DVAP_DB_PASSWORD@postgres:5432/dvap
APP_DATABASE_URL=postgresql://dvap_app:FAKE_DVAP_DB_PASSWORD@postgres:5432/dvap

# ---------------------------------------------------------------------------
# Worker: synthetic seed file path (CONTRACTS §7)
# ---------------------------------------------------------------------------
DVAP_SEEDS_FILE=/app/seeds/synthetic.env
DVAP_EXTRA_SEEDS_FILE=/app/seeds/canarytokens.local.env

# ---------------------------------------------------------------------------
# Optional Canarytokens.org AWS token generation
# ---------------------------------------------------------------------------
# CANARYTOKENS_EMAIL=security@example.com
# CANARYTOKENS_WEBHOOK_URL=https://example.com/security/canary-webhook
# CANARYTOKENS_MEMO=DVAP local repository assessment AWS credential
# CANARYTOKENS_BASE_URL=https://canarytokens.org

# ---------------------------------------------------------------------------
# Worker resource caps
# ---------------------------------------------------------------------------
WORKER_CPUS=1.0           # CPU quota for the worker container
WORKER_MEMORY=1G          # Memory limit for the worker container
WORKER_PIDS_LIMIT=256     # Max PIDs in the worker container

# ---------------------------------------------------------------------------
# Scan / ingestion limits
# ---------------------------------------------------------------------------
# DVAP_MAX_UPLOAD_MB=20     # Maximum archive upload size in megabytes
# DVAP_GIT_TIMEOUT=30       # Hard timeout for git clone --depth 1
# DVAP_GIT_MAX_BYTES=52428800
# DVAP_BEACON_TIMEOUT=5     # Outbound callback timeout from analyzer payloads
